# Copy this file to .env and fill in real values:  cp .env.example .env
# .env is gitignored — your real values never get committed.

# --- Server / system ---
SERVER_NAME=home-server
RAID_MOUNT=/mnt/storage
# Path to YOUR server's markdown guide, shown on the in-app "Server Guide" page.
# Leave unset to show the committed example template; point it at your own
# (gitignored, host-specific) doc to show that instead.
# SERVER_GUIDE_FILE=/home/you/docs/SERVER_GUIDE.md

# --- Plex ---
PLEX_URL=http://localhost:32400
PLEX_TOKEN=your-token-here

# --- Backend ---
API_PORT=8000
# Path to the Docker socket on the host (mounted read-only into the backend)
DOCKER_SOCKET=/var/run/docker.sock

# --- Config backup (age) ---
# Public ("recipient") key the backup script encrypts to. Generate a keypair on
# your OWN machine (age-keygen); put the PUBLIC key here, keep the private key in
# a password manager. The server can encrypt but never decrypt.
AGE_RECIPIENT=age1yourpublickeyhere
# Directory (on persistent storage) where encrypted backups are written.
# Keep it under RAID_MOUNT so the UI can list it via the existing mount.
BACKUP_DIR=/mnt/storage/backups/home-hq
# How many backups to keep before pruning the oldest.
BACKUP_RETENTION=14

# --- Frontend ---
VITE_API_BASE=/api
