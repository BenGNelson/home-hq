# --- Secrets / host-specific config ---
# .env holds REAL values (tokens, paths). Never commit it.
.env
# Per-host backup path list (host-specific paths). Use backup.includes.example.
scripts/backup.includes
# Per-host "How it works" notes (container descriptions). Generic UI is committed.
frontend/src/modules/guide/host.local.jsx
# Real forbidden-pattern list for the pre-commit privacy hook (this machine's
# hostname / IPs / paths). The hook machinery + a generic .example are committed.
.githooks/*.local

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/

# --- Node / frontend ---
node_modules/
dist/
# Self-hosted EmulatorJS engine/cores (~300 MB of third-party WASM). Pinned and
# fetched by scripts/fetch-emulatorjs.sh — never committed.
frontend/public/emulatorjs/

# Visual-regression screenshots — captured from the LIVE app, so they contain
# real host data (tailnet device names, Plex titles, catalog rooms). Host-side
# only; never committed to the public repo. The harness (e2e/visual.py) IS
# committed; its baseline/current/diff PNGs are not.
e2e/screenshots/

# Lighthouse audit output (diagnostic reports, reference the local URL).
lighthouse-report/

# --- Editor / OS noise ---
.DS_Store
*.swp
